// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Builder => company which provide a Electricity service

enum Role {
  USER
  SOCIETY_ADMIN
  BUILDER_ADMIN
}

model Builder {
  id        Int       @id @default(autoincrement()) // @id => Act as Primary key & @default(autoincrement()) => auto id
  name      String    
  location  String
  createdAt DateTime  @default(now()) // @default(now()) => Add current date n time
  societies Society[]
}

model Society {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  flats     Flat[]
  users     User[]
  builderId Int
  builder   Builder  @relation(fields: [builderId], references: [id]) // use to build relationship
  createdAt DateTime @default(now())
  
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  flats     Flat[]
  societyId Int? // ? ka matlab ki optional hai
  society   Society? @relation(fields: [societyId], references: [id])
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Flat {
  id         Int      @id @default(autoincrement())
  flatNumber Int      
  floor      Int     
  societyId  Int
  society    Society  @relation(fields: [societyId], references: [id])
  ownerId    Int
  owner      User     @relation(fields: [ownerId], references: [id])
  createdAt  DateTime @default(now())
   @@unique([flatNumber, floor , societyId]) // @id ek hi baar use ho sakti hai therefore isko unique batane keliya aise kiya hai
}
